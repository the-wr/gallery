# Copy to .env for local development. Local differs from prod only in values.

# Where SQLite db + assets live (filesystem storage driver).
DATA_DIR=./data

# Public base URL. When http://localhost, the share cookie's Secure flag is
# relaxed so the unlock flow is testable without TLS (TDD §13.2).
BASE_URL=http://localhost:5173

# 'filesystem' (local + single-VPS v1) or 's3' (dormant, scale-out later).
STORAGE_DRIVER=filesystem

# Owner auth (hashed at rest in a later milestone; plain here for dev bring-up).
OWNER_PASSWORD=changeme

# 'stub' swaps a placeholder for static maps when local geometry is absent,
# so map work doesn't block the rest of the build (TDD §13.2).
MAP_RENDER=stub
